<%@ page contentType="text/html;charset=UTF-8" %>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>

<!DOCTYPE html>
<html>
<head>
    <title>My Contacts</title>

    <style>

        body{
            margin:0;
            font-family:Arial;
            background:#f4f4f4;
        }

        .navbar{
            background:#4f46e5;
            padding:15px;
            display:flex;
            justify-content:space-between;
            color:white;
        }

        .nav-links a{
            color:white;
            margin-left:15px;
            text-decoration:none;
        }

        .container{
            display:flex;
            justify-content:center;
            margin-top:40px;
        }

        .card{
            width:800px;
            background:white;
            padding:25px;
            border-radius:10px;
        }

        table{
            width:100%;
            border-collapse:collapse;
        }

        th{
            background:#4f46e5;
            color:white;
            padding:12px;
        }

        td{
            padding:12px;
            border-bottom:1px solid #ddd;
        }

        .btn{
            padding:5px 10px;
            color:white;
            border:none;
            border-radius:4px;
            text-decoration:none;
        }

        .edit{ background:orange; }
        .delete{ background:red; }

        .msg{
            text-align:center;
            color:green;
            margin-bottom:10px;
        }

    </style>
</head>

<body>

<div class="navbar">
    <div>Contact Manager</div>

    <div class="nav-links">
        <a href="index.jsp">Home</a>
        <a href="contacts.jsp">Contacts</a>
    </div>
</div>

<div class="container">

    <div class="card">

        <h2 style="text-align:center;">My Contacts</h2>

        <!-- MESSAGE -->
        <c:if test="${not empty sessionScope.message}">
            <div class="msg">${sessionScope.message}</div>
            <c:remove var="message" scope="session"/>
        </c:if>

        <table>

            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>

            <c:forEach var="c" items="${sessionScope.contacts}">

                <tr>
                    <td>${c.name}</td>
                    <td>${c.phone}</td>
                    <td>${c.email}</td>

                    <td>
                        <a class="btn edit"
                           href="editContact?email=${c.email}">
                           Edit
                        </a>

                        <a class="btn delete"
                           href="deleteContact?email=${c.email}">
                           Delete
                        </a>
                    </td>
                </tr>

            </c:forEach>

        </table>

    </div>

</div>

</body>
</html>