/* =========================
   GLOBAL STYLES
========================= */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #eef2ff, #f8fafc);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    color: #1e293b;
}

/* =========================
   MAIN CARD
========================= */

.contact-card {
    width: 100%;
    max-width: 500px;
    background: #ffffff;
    padding: 40px;
    border-radius: 20px;
    box-shadow:
        0 10px 25px rgba(0, 0, 0, 0.08),
        0 4px 10px rgba(0, 0, 0, 0.04);
    animation: fadeIn 0.4s ease-in-out;
}

/* =========================
   HEADER
========================= */

.contact-card h1 {
    text-align: center;
    font-size: 38px;
    margin-bottom: 10px;
    color: #0f172a;
}

.subtitle {
    text-align: center;
    color: #64748b;
    margin-bottom: 30px;
    font-size: 16px;
}

/* =========================
   BUTTONS
========================= */

.btn-primary,
.btn-success {
    border: none;
    border-radius: 12px;
    padding: 14px;
    width: 100%;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s ease;
}

.btn-primary {
    background: #2563eb;
    color: white;
    margin-bottom: 20px;
}

.btn-primary:hover {
    background: #1d4ed8;
    transform: translateY(-2px);
}

.btn-success {
    background: #10b981;
    color: white;
    margin-top: 10px;
}

.btn-success:hover {
    background: #059669;
    transform: translateY(-2px);
}

/* =========================
   FORM
========================= */

.form-group {
    margin-bottom: 20px;
}

label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #334155;
}

.form-control {
    width: 100%;
    padding: 14px;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    font-size: 15px;
    transition: all 0.3s ease;
    background-color: #f8fafc;
}

.form-control:focus {
    outline: none;
    border-color: #2563eb;
    background: white;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
}

/* =========================
   CONTACT TABLE
========================= */

.table-container {
    margin-top: 30px;
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
    border-radius: 14px;
    overflow: hidden;
    background: white;
}

thead {
    background: #2563eb;
    color: white;
}

th,
td {
    padding: 16px;
    text-align: left;
}

tbody tr {
    border-bottom: 1px solid #e2e8f0;
}

tbody tr:hover {
    background: #f8fafc;
}

/* =========================
   EMPTY MESSAGE
========================= */

.empty-message {
    text-align: center;
    margin-top: 20px;
    color: #64748b;
}

/* =========================
   ANIMATION
========================= */

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* =========================
   MOBILE RESPONSIVE
========================= */

@media (max-width: 600px) {

    .contact-card {
        padding: 25px;
    }

    .contact-card h1 {
        font-size: 30px;
    }

    .subtitle {
        font-size: 14px;
    }

    th,
    td {
        padding: 12px;
        font-size: 14px;
    }
}