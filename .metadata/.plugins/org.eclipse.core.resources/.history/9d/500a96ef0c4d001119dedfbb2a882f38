package com.wipro.ORMDemo;

import java.util.List;
import java.util.Scanner;

import org.springframework.context.ApplicationContext;
import org.springframework.context.annotation.AnnotationConfigApplicationContext;

import com.wipro.ORMDemo.dao.EmployeeDao;
import com.wipro.ORMDemo.dao.EmployeeDaoImpl;
import com.wipro.ORMDemo.entity.Employee;

public class App {

    public static void main(String[] args) {

    	ApplicationContext context =
    	        new AnnotationConfigApplicationContext(MyConfig.class);

    	EmployeeDaoImpl dao = context.getBean(EmployeeDaoImpl.class);

     

        Scanner sc = new Scanner(System.in);

        while (true) {

            System.out.println("\n1.Save 2.Get 3.GetAll 4.Update 5.Delete 6.Exit");
            int choice = sc.nextInt();

            switch (choice) {

            case 1:
                System.out.println("Enter id name salary");
                dao.saveEmployee(new Employee(sc.nextInt(), sc.next(), sc.nextDouble()));
                break;

            case 2:
                System.out.println("Enter id");
                Employee e = dao.getEmployee(sc.nextInt());
                System.out.println(e.getName() + " " + e.getSalary());
                break;

            case 3:
                List<Employee> list = dao.getAll();
                for (Employee emp : list) {
                    System.out.println(emp.getId() + " " + emp.getName() + " " + emp.getSalary());
                }
                break;

            case 4:
                System.out.println("Enter id");
                Employee emp = dao.getEmployee(sc.nextInt());

                System.out.println("Enter new name and salary");
                emp.setName(sc.next());
                emp.setSalary(sc.nextDouble());

                dao.updateEmployee(emp);
                break;

            case 5:
                System.out.println("Enter id");
                dao.deleteEmployee(sc.nextInt());
                break;

            case 6:
                System.exit(0);
            }
        }
    }
}